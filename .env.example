# Remote A2A endpoint for the fare-engine service (Go, Cloud Run URL or localhost).
# The orchestrator calls this as a RemoteA2aAgent.
FARE_ENGINE_URL=http://localhost:8081

# Route Gemini calls through Vertex AI.
# Set GOOGLE_GENAI_USE_VERTEXAI=TRUE and provide the project/location when
# running in Cloud Run with ADC from the metadata server. For local dev with
# Gemini API key, leave these unset and use GEMINI_API_KEY instead.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Gemini API key for local development (not used when GOOGLE_GENAI_USE_VERTEXAI=TRUE).
GEMINI_API_KEY=your-api-key-here

# Service-account JSON key for invoking the fare_engine Cloud Run service.
# Required for local dev when FARE_ENGINE_URL points at a deployed Cloud Run
# service with --no-allow-unauthenticated. The SA must have roles/run.invoker
# on the fare_engine service. User ADC (`gcloud auth application-default login`)
# cannot mint ID tokens, so a service-account key is needed.
# Mint one for the orchestrator's runtime SA (the one with run.invoker on the
# engine) and store it OUTSIDE the repo:
#   gcloud iam service-accounts keys create \
#     ~/.config/gcloud/keys/travel-prequal-sa-${PROJECT_ID}.json \
#     --iam-account "travel-prequal-sa@${PROJECT_ID}.iam.gserviceaccount.com" \
#     --project "${PROJECT_ID}"
# The same key doubles as ADC for the Vertex route above (the SA already has
# roles/aiplatform.user), so one key covers both Gemini calls and engine auth.
# Rotate/revoke: gcloud iam service-accounts keys delete <key-id> ...
# Leave unset when deploying to Cloud Run — the metadata server is used
# automatically.
GOOGLE_APPLICATION_CREDENTIALS=
