{
  "eval_set_id": "intake_baseline",
  "name": "intake baseline",
  "description": "Intake agent parses natural-language trip requests into structured IntakeOutput, including trip_type (one_way/round_trip). Graded on response match (no tools). All traveler data is obviously fake per CLAUDE.md data-hygiene rule.",
  "eval_cases": [
    {
      "eval_id": "complete_single_adult_economy",
      "conversation": [
        {
          "invocation_id": "intake-1",
          "user_content": {
            "role": "user",
            "parts": [
              {
                "text": "Hi, I'm Test Traveler (test.traveler@example.com, employee 00001, Engineering). I need to fly from JFK to LAX on 2026-09-15, returning 2026-09-20, economy class, for a client meeting. Just me, one adult."
              }
            ]
          },
          "final_response": {
            "role": "model",
            "parts": [
              {
                "text": "{\"traveler\":{\"name\":\"Test Traveler\",\"email\":\"test.traveler@example.com\",\"employee_id\":\"00001\",\"department\":\"Engineering\"},\"trip\":{\"origin\":\"JFK\",\"destination\":\"LAX\",\"trip_type\":\"round_trip\",\"departure_date\":\"2026-09-15\",\"return_date\":\"2026-09-20\",\"passengers\":[{\"count\":1,\"type\":\"adult\"}],\"travel_class\":\"economy\",\"trip_purpose\":\"client_meeting\"},\"missing_fields\":[],\"ready_for_policy\":true}"
              }
            ]
          },
          "intermediate_data": { "tool_uses": [], "tool_responses": [] }
        }
      ],
      "session_input": { "app_name": "intake", "user_id": "u-eval", "state": {} }
    },
