{
  "eval_set_id": "fare_prep_baseline",
  "name": "fare_prep baseline",
  "description": "fare_prep reads {intake_output} from session state and calls build_fare_request exactly once with the trip's origin/destination/trip_type/dates/class/passengers. For one_way trips the return_date argument must be omitted. Graded primarily on the tool trajectory (deterministic inputs); the derived fare_request numbers depend on the run date, so response_match has a lenient threshold.",
  "eval_cases": [
    {
      "eval_id": "domestic_round_trip_single_adult",
      "conversation": [
        {
          "invocation_id": "prep-1",
          "user_content": {
            "role": "user",
            "parts": [{ "text": "Prepare the fare request for this trip." }]
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "build_fare_request",
                "args": {
                  "origin": "JFK",
                  "destination": "LAX",
                  "departure_date": "2026-09-15",
                  "travel_class": "economy",
                  "passengers": [{ "count": 1, "type": "adult" }],
                  "trip_type": "round_trip",
                  "return_date": "2026-09-20"
                }
              }
            ],
            "tool_responses": []
          }
        }
      ],
      "session_input": {
        "app_name": "fare_prep",
        "user_id": "u-eval",
        "state": {
          "intake_output": {
            "traveler": { "name": "Test Traveler", "email": "test.traveler@example.com", "employee_id": "00001", "department": "Engineering" },
            "trip": { "origin": "JFK", "destination": "LAX", "trip_type": "round_trip", "departure_date": "2026-09-15", "return_date": "2026-09-20", "passengers": [{ "count": 1, "type": "adult" }], "travel_class": "economy", "trip_purpose": "client_meeting" },
            "missing_fields": [],
            "ready_for_policy": true
          }
        }
      }
    },
